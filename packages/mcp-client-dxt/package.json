{
  "name": "@azzas/mcp-client-dxt",
  "version": "1.0.1",
  "private": true,
  "description": "Azzas MCP DXT client for Claude Desktop",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:dxt": "npm run build && node scripts/build-dxt.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "interop:mint": "tsx scripts/mint-for-interop.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "jsonwebtoken": "^9.0.2",
    "open": "^10.1.0",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "archiver": "^7.0.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
