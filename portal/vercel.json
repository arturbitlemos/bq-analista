{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/auth.js": { "maxDuration": 10 },
    "api/share.js": { "maxDuration": 30 },
    "api/mcp/auth/callback.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/onboarding", "destination": "/onboarding.html" }
  ],
  "headers": [
    {
      "source": "/analyses/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "private, no-store" }]
    },
    {
      "source": "/library/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "private, no-store" }]
    }
  ]
}
